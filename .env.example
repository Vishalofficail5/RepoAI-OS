# Optional: enables OpenAI Responses API synthesis after repository retrieval.
OPENAI_API_KEY=
OPENAI_MODEL=

# OAuth authentication
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SESSION_SECRET=

# Optional: enables MongoDB persistence for users, sessions, repositories, and investigations.
MONGODB_URI=
MONGODB_DATABASE=repoai
# Optional: use public DNS when your network blocks MongoDB Atlas SRV lookups.
MONGODB_DNS_SERVERS=

# Optional: created from the signed-in workspace menu for the local MCP server.
REPOAI_MCP_TOKEN=

# Optional: permits repository ingestion outside this workspace.
# REPOAI_REPOSITORY_ROOT=C:\Projects
